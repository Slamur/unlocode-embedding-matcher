+def find_csv_files(
+    directory: Path, 
+    filename_substring: str,
+) -> Sequence[Path]:
+    files = sorted(directory.glob(f"*{filename_substring}*.csv"))
+
+    if not files:
+        raise RuntimeError(f"No files matching substring '{filename_substring}' found in {directory}")
+    
+    return files
